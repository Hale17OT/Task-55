# PostgreSQL
# REQUIRED: Set a strong password (used by both PostgreSQL and the API)
DB_PASSWORD=dev_password_change_me
DATABASE_URL=postgres://studioops:dev_password_change_me@localhost:54320/studioops

# API
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:4200

# Security
# REQUIRED: In production, these MUST be changed from defaults or the API will refuse to start.
# JWT_SECRET must be at least 32 characters. ENCRYPTION_KEY must be exactly 64 hex characters.
JWT_SECRET=dev_jwt_secret_change_me_at_least_32_characters_long
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Storage
STORAGE_ROOT=./data/media

# Seeding (set to true on first run to create demo accounts; disable after)
# SEED_DATA=true
