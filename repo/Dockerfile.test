FROM node:22-alpine

# Playwright system dependencies (Chromium)
RUN apk add --no-cache \
  chromium \
  nss \
  freetype \
  harfbuzz \
  ca-certificates \
  ttf-freefont

# Tell Playwright to use the system Chromium instead of downloading its own
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser

WORKDIR /app

# Copy full workspace
COPY package.json package-lock.json* tsconfig.base.json ./
COPY packages/ packages/
COPY apps/ apps/
COPY scripts/ scripts/
COPY e2e/ e2e/

# Install all dependencies (including devDependencies for tests)
RUN npm install --workspaces --include-workspace-root

# Build workspace packages so dist/ directories exist for module resolution
RUN npm run build --workspace=packages/shared --workspace=packages/db --if-present

# Seed DB with test data then run all tests via the existing runner in strict CI mode
COPY scripts/docker-test-entrypoint.sh /docker-test-entrypoint.sh
RUN chmod +x /docker-test-entrypoint.sh

CMD ["/docker-test-entrypoint.sh"]
